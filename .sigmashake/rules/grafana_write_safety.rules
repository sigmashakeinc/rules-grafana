# grafana_write_safety.rules
# Technology: grafana | Capability: write

rule grafana-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "allow_embedding = true"
  MESSAGE "Blocked an unsafe pattern in grafana. Use the recommended best practices for 2025/2026."
}

rule grafana-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "grafana-cli"
  MESSAGE "You are using an outdated API for grafana. Please upgrade to the newer API."
}
